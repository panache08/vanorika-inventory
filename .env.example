# Migrations/seed only (superuser/owner role). Used for `prisma migrate deploy`
# and `prisma db seed`. Never used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Runtime connection (non-superuser app_user, no BYPASSRLS). This is what the
# running app actually queries through — RLS is enforced against this role.
# Include a connection_limit sized to your Postgres plan (local dev uses 25).
# On Neon, point this at the POOLED connection string.
APP_DATABASE_URL="postgresql://app_user:PASSWORD@HOST/DB?sslmode=require&connection_limit=25"

AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_TRUST_HOST="true"
